# generator is a called lazy fn it doesnt work until needed 
# geerator are special was to produce  value  one by one 
#instead of creating at once

#start execution 
#one value return
#pause itself
#remember its position


def counter(max_value):
    count = 1
    while count <= max_value:
        yield count  
        count += 1

for num in counter(5):
    print(num)


